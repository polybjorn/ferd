# Copy to .env and adjust. .env is gitignored.
# Compose reads these automatically via ${VAR} interpolation in compose.yml.

# Host port to publish the container on. Change if 8090 is taken.
FERD_HOST_PORT=8090

# Cookie security. Keep "false" for plain-HTTP localhost; set "true" when
# behind a reverse proxy with TLS.
FERD_SECURE_COOKIES=false

# Seed an operator account on first start. Ignored once any user exists.
# Leave blank to register the first account through the web UI instead.
FERD_INITIAL_USER=
FERD_INITIAL_PASSWORD=

# Require a one-time setup token (printed to the container log) for the
# first registration. Recommended for public deploys.
FERD_REQUIRE_SETUP_TOKEN=false

# Optional uid/gid override. Leave unset to auto-adopt the owner of ./data
# (the typical case: whoever ran `mkdir data`). Only set these if you need
# the container to run as a specific user different from the data dir's owner.
#PUID=1000
#PGID=1000
