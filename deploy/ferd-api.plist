<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS launchd plist for Ferd API.
  Install to ~/Library/LaunchAgents/local.ferd-api.plist (per-user)
  or /Library/LaunchDaemons/local.ferd-api.plist (system).
  Then: launchctl load ~/Library/LaunchAgents/local.ferd-api.plist

  Adjust the paths below to your install. No socket activation; the process
  runs continuously and respects idle_exit_seconds in config if you want it
  to exit when inactive (KeepAlive will then restart it on the next request,
  which isn't ideal on launchd; for true on-demand on macOS use Sockets keys).
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>local.ferd-api</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/YOU/ferd/tools/api.py</string>
    <string>--config</string>
    <string>/Users/YOU/ferd/tools/config.json</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/YOU/ferd</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/YOU/ferd/tools/ferd-api.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/YOU/ferd/tools/ferd-api.log</string>
</dict>
</plist>
